---
import ComponentPreview from "../../layouts/ComponentPreview.astro";
import HighlightedCode from "../../components/HighlightedCode.astro";
import {
  BasicRow,
  AccentsRow,
  MinimalRow,
  ClickableRow,
  ActionsRow,
} from "../../previews/agent-card";
import { LiveAgentCardSnippet } from "../../previews/agent-card-live";
import agentCardSource from "@ds/components/agent-card/index.tsx?raw";
---

<ComponentPreview
  kicker="COMPONENTES · DADOS & CONTEÚDO"
  title="AgentCard"
  group="Dados & conteúdo"
  storybookId="components-agentcard--default"
  sourcePath="ui_kit/components/agent-card"
  lede='Cartão-resumo de um agente de IA no Control Center. Reúne <b>identidade</b> (ícone temático + nome + papel), <b>status operacional</b>, <b>KPIs</b> (até 3) e <b>última execução</b>. Quatro accents (<code class="inline">violet · orange · blue · green</code>) e seis status (<code class="inline">idle · working · active · paused · error · offline</code>). Apenas tokens semânticos.'
>
  <!-- ============ BASIC ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Padrão</h2>
      <small>identidade + status + métricas + última execução</small>
    </div>
    <div class="preview">
      <BasicRow client:load />
    </div>
    <p class="preview-caption">
      O <code class="inline">accent</code> da raiz pinta a barra lateral e o
      tint do avatar; o <code class="inline">status</code> cascateia para o
      pill (com texto + dot). Texto + cor sempre — a cor isolada não comunica
      estado.
    </p>
  </section>

  <!-- ============ ACCENTS · STATES ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Accents · estados</h2>
      <small>violet · orange · blue · green · active · idle · paused · error</small>
    </div>
    <div class="preview">
      <AccentsRow client:load />
    </div>
    <p class="preview-caption">
      Brand: <b>laranja</b> sinaliza agente em ação; <b>violeta</b> é o estado
      base (idle/active discreto); <b>vermelho</b> aparece em erro; <b>verde</b>
      indica conclusão/saúde. O accent define a hierarquia visual; o status,
      o estado momentâneo.
    </p>
  </section>

  <!-- ============ MINIMAL ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Mínimo · sem métricas</h2>
      <small>quando a lista é densa ou os KPIs ainda não estão maduros</small>
    </div>
    <div class="preview">
      <MinimalRow client:load />
    </div>
  </section>

  <!-- ============ CLICKABLE ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Clicável</h2>
      <small>card inteiro como ação</small>
    </div>
    <div class="preview">
      <ClickableRow client:load />
    </div>
    <p class="preview-caption">
      Com <code class="inline">interactive</code>, a raiz fica focável
      (<code class="inline">tabindex=0</code>), ganha anel de foco e ativa
      <code class="inline">onClick</code> por mouse, <b>Enter</b> e
      <b>Espaço</b>. <b>Enter/Espaço em filhos focáveis</b> (botão no Footer)
      não são sequestrados — o card só ativa quando o evento sai dele mesmo.
    </p>
  </section>

  <!-- ============ ACTIONS ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Com ações</h2>
      <small>AgentCard.Footer + Button</small>
    </div>
    <div class="preview">
      <ActionsRow client:load />
    </div>
  </section>

  <!-- ============ PLAYGROUND ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Playground</h2>
      <small>edite o JSX e veja ao vivo</small>
    </div>
    <LiveAgentCardSnippet client:load />
  </section>

  <!-- ============ PROPS ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Props</h2>
      <small>API pública (raiz + subcomponentes)</small>
    </div>
    <div class="props">
      <table>
        <thead>
          <tr><th>Prop</th><th>Tipo</th><th>Default</th><th>Descrição</th></tr>
        </thead>
        <tbody>
          <tr>
            <td class="name">accent</td>
            <td class="type">"violet" | "orange" | "blue" | "green"</td>
            <td class="default">"violet"</td>
            <td class="desc">Cor do acento (barra lateral + tint do avatar). Cascateia via contexto.</td>
          </tr>
          <tr>
            <td class="name">status</td>
            <td class="type">AgentStatus</td>
            <td class="default">"idle"</td>
            <td class="desc">idle · working · active · paused · error · offline. Cascateia via contexto.</td>
          </tr>
          <tr>
            <td class="name">variant</td>
            <td class="type">"default" | "elevated" | "outlined"</td>
            <td class="default">"default"</td>
            <td class="desc">Superfície do card (shadow-sm / shadow-md / borda forte).</td>
          </tr>
          <tr>
            <td class="name">interactive</td>
            <td class="type">boolean</td>
            <td class="default">false</td>
            <td class="desc">Foco visível + hover + ativação por Enter/Espaço (dispara onClick).</td>
          </tr>
          <tr>
            <td class="name">as</td>
            <td class="type">"article" | "section" | "div"</td>
            <td class="default">"article"</td>
            <td class="desc">Elemento semântico da raiz.</td>
          </tr>
          <tr>
            <td class="name">AgentCard.Avatar</td>
            <td class="type">{`{ icon?: ReactNode, accent? }`}</td>
            <td class="default">{`<Bot />`}</td>
            <td class="desc">Ícone temático em quadrado 44×44 com tint do accent. Agentes são sistemas — sem foto.</td>
          </tr>
          <tr>
            <td class="name">AgentCard.Name</td>
            <td class="type">{`{ as?: "h1".."h6" }`}</td>
            <td class="default">"h3"</td>
            <td class="desc">Nome do agente (heading).</td>
          </tr>
          <tr>
            <td class="name">AgentCard.Status</td>
            <td class="type">{`{ status?, label? }`}</td>
            <td class="default">herda do root</td>
            <td class="desc">Pill com role="status"; dot + rótulo localizado; glow ring em "active".</td>
          </tr>
          <tr>
            <td class="name">AgentCard.Metric</td>
            <td class="type">{`{ label, value }`}</td>
            <td class="default">—</td>
            <td class="desc">KPI individual (label + value). Use até 3 por card.</td>
          </tr>
          <tr>
            <td class="name">AgentCard.LastRun</td>
            <td class="type">{`{ icon?: ReactNode | null }`}</td>
            <td class="default">{`<Clock />`}</td>
            <td class="desc">Timestamp humano (ex.: "há 2 min"). Passe icon={`{null}`} para ocultar o ícone.</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="preview-caption">
      Demais slots: <code class="inline">Header</code>,
      <code class="inline">Role</code>, <code class="inline">Description</code>,
      <code class="inline">Capabilities</code> / <code class="inline">Capability</code>
      (tags opcionais), <code class="inline">Metrics</code>,
      <code class="inline">Footer</code>. Helpers públicos:
      <code class="inline">AGENT_STATUS_LABELS</code>,
      <code class="inline">agentStatusToBadgeVariant</code>, tipos
      <code class="inline">AgentStatus</code> /
      <code class="inline">AgentAccent</code>.
    </p>
  </section>

  <!-- ============ SOURCE ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Código-fonte</h2>
      <small>ui_kit/components/agent-card/index.tsx</small>
    </div>
    <HighlightedCode
      code={agentCardSource}
      language="tsx"
      filename="ui_kit/components/agent-card/index.tsx"
      maxHeight="520px"
      showLineNumbers
    />
  </section>

  <!-- ============ A11Y ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Acessibilidade</h2>
      <small>WCAG 2.1 AA</small>
    </div>
    <div class="a11y">
      <ul>
        <li><span>A raiz é um <b><code class="inline">&lt;article&gt;</code></b> semântico (ou <code class="inline">section</code>/<code class="inline">div</code> via <code class="inline">as</code>).</span></li>
        <li><span><b>Status por cor + texto</b>: o pill anuncia o rótulo via <code class="inline">role="status"</code>; o ponto colorido é decorativo (<code class="inline">aria-hidden</code>). A cor nunca é o único indicador.</span></li>
        <li><span><b>Métricas</b> são <code class="inline">&lt;dl&gt;</code> com pares <code class="inline">&lt;dt&gt;</code> (label) + <code class="inline">&lt;dd&gt;</code> (valor) — leitor de tela anuncia como lista de definições.</span></li>
        <li><span><b>Interativo</b>: a raiz fica focável (<code class="inline">tabindex=0</code>), com anel de foco visível, ativa por <b>Enter</b>/<b>Espaço</b>, e não sequestra teclado de filhos focáveis. Use <code class="inline">aria-label</code> quando o card todo for a ação.</span></li>
        <li><span><b>Ícones decorativos</b> (avatar, dot, accent-stripe) ficam ocultos para leitor de tela — a informação está no texto.</span></li>
        <li><span><b>Contraste</b>: tokens semânticos validados em AA contra fundos light e dark (<code class="inline">--success-soft + --signal-green-700</code>, <code class="inline">--danger-soft + --signal-red-700</code>, <code class="inline">--guardia-yellow-100 + --guardia-yellow-900</code>).</span></li>
      </ul>
    </div>
  </section>
</ComponentPreview>
