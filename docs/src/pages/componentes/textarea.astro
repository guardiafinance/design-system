---
import ComponentPreview from "../../layouts/ComponentPreview.astro";
import HighlightedCode from "../../components/HighlightedCode.astro";
import {
  BasicRow,
  SizesRow,
  StatesRow,
  CounterRow,
  AutoSizeRow,
  ResizeRow,
  DisabledRow,
  FormSubmitRow,
} from "../../previews/textarea";
import { LiveTextareaSnippet } from "../../previews/textarea-live";
import textareaSource from "@ds/components/textarea/index.tsx?raw";
---

<ComponentPreview
  kicker="COMPONENTES · FORMS"
  title="Textarea"
  group="Forms"
  storybookId="components-textarea--default"
  sourcePath="ui_kit/components/textarea"
  lede='Campo de texto multilinha. Paridade com <code class="inline">Input</code> (sizes sm/md/lg, estados default/error/success, shortcut <code class="inline">invalid</code>, <code class="inline">disabled</code>) e extras próprios: contador (<code class="inline">showCount</code>), auto-grow (<code class="inline">autoSize</code> + <code class="inline">maxRows</code>), controle de <code class="inline">resize</code>.'
>
  <!-- ============ BASIC ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Padrão</h2>
      <small>placeholder + foco</small>
    </div>
    <div class="preview">
      <BasicRow client:load />
    </div>
  </section>

  <!-- ============ SIZES ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Tamanhos</h2>
      <small>sm 60 · md 84 (default) · lg 112 (min-height em px)</small>
    </div>
    <div class="preview">
      <SizesRow client:load />
    </div>
  </section>

  <!-- ============ STATES ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Estados</h2>
      <small>default · error · success</small>
    </div>
    <div class="preview">
      <StatesRow client:load />
    </div>
    <p class="preview-caption">
      <code class="inline">invalid={`{true}`}</code> é shortcut para
      <code class="inline">state="error"</code> +
      <code class="inline">aria-invalid="true"</code>. Para integração com FormLayout,
      o Field injeta <code class="inline">invalid</code> automaticamente quando há erro.
    </p>
  </section>

  <!-- ============ COUNTER ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Contador</h2>
      <small>showCount · com ou sem maxLength</small>
    </div>
    <div class="preview">
      <CounterRow client:load />
    </div>
    <p class="preview-caption">
      O contador é <code class="inline">aria-hidden="true"</code> — feedback puramente visual.
      Para feedback de leitor de tela (ex: "Você ultrapassou o limite"), anexe
      <code class="inline">aria-describedby</code> a um sibling com <code class="inline">role="status"</code>.
    </p>
  </section>

  <!-- ============ AUTOSIZE ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>AutoSize</h2>
      <small>autoSize + maxRows</small>
    </div>
    <div class="preview">
      <AutoSizeRow client:load />
    </div>
    <p class="preview-caption">
      Cresce com o conteúdo até <code class="inline">maxRows</code>; depois disso, o overflow
      vira scroll interno. Quando <code class="inline">autoSize</code> está ligado, o
      <code class="inline">resize</code> default vira <code class="inline">"none"</code> (handle manual conflita) —
      passe <code class="inline">resize</code> explícito para ter ambos.
    </p>
  </section>

  <!-- ============ RESIZE ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Resize</h2>
      <small>none · vertical (default) · both</small>
    </div>
    <div class="preview">
      <ResizeRow client:load />
    </div>
  </section>

  <!-- ============ DISABLED ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Disabled</h2>
      <small>data-disabled no wrapper + disabled no textarea</small>
    </div>
    <div class="preview">
      <DisabledRow client:load />
    </div>
  </section>

  <!-- ============ FORM ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Em formulário</h2>
      <small>name + required + FormData</small>
    </div>
    <div class="preview">
      <FormSubmitRow client:load />
    </div>
    <p class="preview-caption">
      Aceita todos os attrs nativos: <code class="inline">name</code>, <code class="inline">required</code>,
      <code class="inline">autoComplete</code>, <code class="inline">rows</code>, <code class="inline">cols</code>,
      <code class="inline">maxLength</code>, <code class="inline">minLength</code>.
    </p>
  </section>

  <!-- ============ PLAYGROUND ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Playground</h2>
      <small>edite o JSX e veja ao vivo</small>
    </div>
    <LiveTextareaSnippet client:load />
  </section>

  <!-- ============ PROPS ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Props</h2>
      <small>API pública</small>
    </div>
    <div class="props">
      <table>
        <thead>
          <tr><th>Prop</th><th>Tipo</th><th>Default</th><th>Descrição</th></tr>
        </thead>
        <tbody>
          <tr>
            <td class="name">size</td>
            <td class="type">"sm" | "md" | "lg"</td>
            <td class="default">"md"</td>
            <td class="desc">Min-heights 60 / 84 / 112 px.</td>
          </tr>
          <tr>
            <td class="name">state</td>
            <td class="type">"default" | "error" | "success"</td>
            <td class="default">"default"</td>
            <td class="desc">Cor da border + ring de focus.</td>
          </tr>
          <tr>
            <td class="name">invalid</td>
            <td class="type">boolean</td>
            <td class="default">false</td>
            <td class="desc">Shortcut para <code class="inline">state="error"</code> + <code class="inline">aria-invalid="true"</code>.</td>
          </tr>
          <tr>
            <td class="name">showCount</td>
            <td class="type">boolean</td>
            <td class="default">false</td>
            <td class="desc">Renderiza contador <code class="inline">aria-hidden</code> bottom-right.</td>
          </tr>
          <tr>
            <td class="name">autoSize</td>
            <td class="type">boolean</td>
            <td class="default">false</td>
            <td class="desc">Auto-grow para caber conteúdo (mede <code class="inline">scrollHeight</code>).</td>
          </tr>
          <tr>
            <td class="name">maxRows</td>
            <td class="type">number</td>
            <td class="default">—</td>
            <td class="desc">Limite de linhas quando <code class="inline">autoSize</code>; depois disso, vira scroll interno.</td>
          </tr>
          <tr>
            <td class="name">resize</td>
            <td class="type">"none" | "vertical" | "both"</td>
            <td class="default">"vertical"</td>
            <td class="desc">CSS resize. Default vira <code class="inline">"none"</code> quando <code class="inline">autoSize</code>.</td>
          </tr>
          <tr>
            <td class="name">disabled</td>
            <td class="type">boolean</td>
            <td class="default">false</td>
            <td class="desc">Bloqueia interação. Wrapper recebe <code class="inline">data-disabled="true"</code>.</td>
          </tr>
          <tr>
            <td class="name">className / wrapperClassName</td>
            <td class="type">string</td>
            <td class="default">—</td>
            <td class="desc">Classe no wrapper. Os dois props somam (alias).</td>
          </tr>
          <tr>
            <td class="name">textareaClassName</td>
            <td class="type">string</td>
            <td class="default">—</td>
            <td class="desc">Classe extra no <code class="inline">&lt;textarea&gt;</code> interno (caso avançado).</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="preview-caption">
      Aceita todos os atributos de <code class="inline">HTMLTextAreaElement</code> exceto <code class="inline">size</code> (sobrescrito pelo prop CVA).
    </p>
  </section>

  <!-- ============ SOURCE ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Código-fonte</h2>
      <small>ui_kit/components/textarea/index.tsx</small>
    </div>
    <HighlightedCode
      code={textareaSource}
      language="tsx"
      filename="ui_kit/components/textarea/index.tsx"
      maxHeight="520px"
      showLineNumbers
    />
  </section>

  <!-- ============ A11Y ============ -->
  <section class="sec">
    <div class="sec-hdr">
      <h2>Acessibilidade</h2>
      <small>WCAG 2.1 AA</small>
    </div>
    <div class="a11y">
      <ul>
        <li><span><b>Native textarea</b>: o ref aponta para o <code class="inline">&lt;textarea&gt;</code> interno — code legado que faz <code class="inline">.focus()</code> ou <code class="inline">.value</code> segue funcionando.</span></li>
        <li><span><b>Foco no wrapper</b>: <code class="inline">focus-within:ring</code> reflete o foco do textarea mesmo quando o usuário arrasta o handle de resize — feedback visual estável.</span></li>
        <li><span><b>aria-invalid</b> auto quando <code class="inline">invalid={`{true}`}</code> ou <code class="inline">aria-invalid</code> explícito.</span></li>
        <li><span><b>Contador aria-hidden</b>: feedback puramente visual; para SR feedback, anexe <code class="inline">aria-describedby</code> a um sibling com <code class="inline">role="status"</code>.</span></li>
        <li><span><b>Compat HTML5</b>: <code class="inline">required</code>, <code class="inline">maxLength</code>, <code class="inline">minLength</code> funcionam — e o <code class="inline">aria-invalid</code> sincroniza com a validação nativa via <code class="inline">:invalid</code>.</span></li>
        <li><span><b>Placeholder nunca substitui label</b> — sempre use <code class="inline">FormLayout.Field label</code> ou <code class="inline">&lt;Label htmlFor&gt;</code> externo.</span></li>
        <li><span><b>autoSize</b> usa <code class="inline">useLayoutEffect</code> para evitar frame de jump; preserva min-height do tamanho mesmo com conteúdo vazio.</span></li>
      </ul>
    </div>
  </section>
</ComponentPreview>
