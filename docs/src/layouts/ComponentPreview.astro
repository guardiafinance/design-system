---
/**
 * ComponentPreview — layout-base para cada página de componente.
 *
 * Visual idêntico às páginas HTML em docs/public/preview/ (colors_and_type.css
 * do wip) + o CSS do design-system carregado para que o componente React
 * renderize com os tokens Guardia aplicados.
 *
 * A página é servida dentro do iframe do index.astro — por isso não inclui
 * navegação (topbar / sidebar).
 */
import "../../../ui_kit/styles/index.css";
import { BookOpen, Github, ExternalLink } from "lucide-react";

export interface Props {
  kicker: string;
  title: string;
  lede: string;
  group: string; // ex: "Primitivos"
  storybookId?: string; // ex: "primitives-button--default"
  sourcePath?: string; // default: ui_kit/components/<slug>
}

const { kicker, title, lede, group, storybookId, sourcePath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const colorsCssUrl = `${base}/colors_and_type.css`;
const baseCssUrl = `${base}/preview/_base.css`;
const storybookRoot = import.meta.env.DEV
  ? "http://localhost:6006/"
  : "https://69e15f3b0534f646ac88774b-cpmytvatdp.chromatic.com/";
const githubRoot = "https://github.com/guardiafinance/design-system/tree/master/";
const storybookUrl = storybookId ? `${storybookRoot}?path=/docs/${storybookId}` : storybookRoot;
const sourceUrl = `${githubRoot}${sourcePath ?? "ui_kit/components"}`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Guardia · {title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href={colorsCssUrl} />
    <link rel="stylesheet" href={baseCssUrl} />
    <style is:global>
      body {
        padding: 44px 48px 72px;
        max-width: 1100px;
      }
      .hdr { margin-bottom: 28px; }
      .hdr h1 {
        font-size: 30px; font-weight: 700; letter-spacing: -0.015em;
        color: var(--fg-strong); margin: 6px 0 4px;
      }
      .hdr .lede {
        font-size: 15px; line-height: 1.6; color: var(--fg);
        max-width: 720px; margin: 14px 0 0;
      }
      .hdr .lede b { color: var(--fg); font-weight: 600; }
      .hdr .hdr-actions { margin-top: 18px; display: flex; gap: 10px; flex-wrap: wrap; }
      .hdr .hdr-actions a {
        font-family: var(--font-mono); font-size: 11.5px;
        color: var(--link); background: var(--bg-subtle);
        padding: 6px 10px; border-radius: var(--radius-sm);
        text-decoration: none; border: 1px solid transparent;
        transition: border-color .12s;
        display: inline-flex; align-items: center; gap: 6px;
      }
      .hdr .hdr-actions a:hover { border-color: var(--ring); }
      .hdr .hdr-actions svg { width: 14px; height: 14px; stroke-width: 1.75; }
      .hdr .hdr-actions .ext { opacity: 0.5; }

      .sec { margin-top: 44px; }
      .sec-hdr {
        display: flex; align-items: baseline; gap: 12px;
        padding-bottom: 10px; border-bottom: 1px solid var(--border);
        margin-bottom: 18px;
      }
      .sec-hdr h2 {
        margin: 0; font-size: 18px; font-weight: 600;
        color: var(--fg); letter-spacing: -0.01em;
      }
      .sec-hdr small {
        font-size: 11px; color: var(--fg-muted);
        letter-spacing: 0.1em; text-transform: uppercase; font-weight: 500;
      }

      /* Blocos de preview — área onde o componente real é renderizado */
      .preview {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 24px;
        display: flex; flex-direction: column; gap: 16px;
        margin-bottom: 12px;
      }
      .preview.row { flex-direction: row; flex-wrap: wrap; align-items: center; }
      .preview.grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
      }
      .preview.bg-subtle { background: var(--bg-subtle); }
      .preview-caption {
        font-size: 11.5px; color: var(--fg-muted);
        font-family: var(--font-mono); letter-spacing: -0.01em;
      }
      .preview-label {
        font-size: 10.5px; font-weight: 600;
        letter-spacing: 0.1em; text-transform: uppercase;
        color: var(--fg-muted);
      }

      /* Código */
      /* Bloco de código — espelha o estilo do <CodeEditor>/<CodeBlock>:
         Violet 900 (Surface Brand) em light, Cinza 900 (Surface 1) em dark
         per diretriz "plot areas usam Surface 1". */
      pre {
        background: var(--violet-900); color: var(--violet-100);
        padding: 14px 18px; border-radius: var(--radius-md);
        overflow-x: auto; font-family: var(--font-mono);
        font-size: 12.5px; line-height: 1.65;
        margin: 0 0 10px;
      }
      :root[data-theme="dark"] pre { background: var(--gray-900); }
      /* Syntax highlighting — orange-200 (keyword), violet-100 (string), violet-300 (comment).
         Mesma palette consumida em light e dark via tokens da escala oficial. */
      pre .k { color: var(--orange-200); }
      pre .s { color: var(--violet-100); }
      pre .c { color: var(--violet-200); font-style: italic; }
      code.inline {
        font-family: var(--font-mono); font-size: 12px;
        background: var(--bg-subtle); color: var(--link);
        padding: 2px 6px; border-radius: 3px;
      }

      /* Tabela de props */
      .props { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden; }
      .props table { width: 100%; border-collapse: collapse; }
      .props th, .props td { text-align: left; padding: 10px 14px; border-bottom: 1px solid var(--border); font-size: 13px; vertical-align: top; }
      .props th { background: var(--bg-subtle); font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600; color: var(--fg-muted); }
      .props tr:last-child td { border-bottom: none; }
      .props td.name { font-family: var(--font-mono); font-size: 12px; color: var(--link); width: 20%; font-weight: 500; }
      .props td.type { font-family: var(--font-mono); font-size: 11.5px; color: var(--fg); width: 28%; }
      .props td.default { font-family: var(--font-mono); font-size: 11.5px; color: var(--fg-muted); width: 14%; }
      .props td.desc { color: var(--fg); font-size: 12.5px; }
      .props .required {
        font-family: var(--font-mono); font-size: 9px; color: var(--signal-red);
        margin-left: 4px; letter-spacing: 0.05em;
      }

      /* a11y checklist */
      .a11y ul { margin: 0; padding: 0; list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 8px 18px; }
      .a11y li {
        font-size: 12.5px; color: var(--fg);
        display: flex; align-items: flex-start; gap: 8px;
        padding: 8px 12px; background: var(--surface);
        border: 1px solid var(--border); border-radius: var(--radius-sm);
      }
      .a11y li::before {
        content: "✓"; color: var(--signal-green);
        font-weight: 700; flex-shrink: 0;
      }
      .a11y li b { color: var(--fg); font-weight: 600; }

      /* Indicador discreto enquanto a iframe espera o primeiro tema do parent */
      html.theme-syncing body { visibility: hidden; }
    </style>
  </head>
  <body>
    <script is:inline>
      // Tema sincronizado com o shell parent (index.astro) via postMessage.
      // Quando carregamos standalone (sem iframe parent), tenta localStorage,
      // depois faz fallback para light. A classe `theme-syncing` em <html>
      // esconde o body por ~50ms para evitar flash claro -> escuro.
      (function () {
        const VALID = new Set(["light", "dark"]);
        const html = document.documentElement;

        function apply(theme) {
          if (!VALID.has(theme)) theme = "light";
          html.setAttribute("data-theme", theme);
          html.classList.remove("theme-syncing");
        }

        // Estado inicial: tenta localStorage (compartilhado com o parent)
        let initial = "light";
        try {
          const stored = localStorage.getItem("guardia-ds-theme");
          if (VALID.has(stored)) initial = stored;
        } catch {}

        const inIframe = window.parent && window.parent !== window;
        if (inIframe) html.classList.add("theme-syncing");
        apply(initial);

        // Escuta mudanças do parent
        window.addEventListener("message", (e) => {
          const data = e.data;
          if (data && data.type === "guardia-ds:theme") apply(data.theme);
        });

        // Sinaliza ao parent que estamos prontos para receber o tema
        if (inIframe) {
          try {
            window.parent.postMessage({ type: "guardia-ds:theme-ready" }, "*");
          } catch {}
          // Failsafe: revela o body em no maximo 80ms se o parent nao responder
          setTimeout(() => html.classList.remove("theme-syncing"), 80);
        }
      })();
    </script>
    <div class="hdr">
      <div class="eyebrow">{kicker}</div>
      <h1>{title}</h1>
      <p class="lede" set:html={lede}></p>
      <div class="hdr-actions">
        <a href={storybookUrl} target="_blank" rel="noreferrer">
          <BookOpen aria-hidden="true" />
          <span>Storybook</span>
          <ExternalLink aria-hidden="true" className="ext" />
        </a>
        <a href={sourceUrl} target="_blank" rel="noreferrer">
          <Github aria-hidden="true" />
          <span>GitHub</span>
          <ExternalLink aria-hidden="true" className="ext" />
        </a>
      </div>
    </div>
    <slot />
    <p
      style="margin-top:56px;padding-top:18px;border-top:1px solid var(--border);font-size:11px;color:var(--fg-muted);letter-spacing:0.08em;text-transform:uppercase;font-weight:500;"
    >
      {group}
    </p>
  </body>
</html>
